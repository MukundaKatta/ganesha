# Ganesha Configuration
# Copy to .env and adjust as needed.

# Default token budget for context windows
GANESHA_MAX_TOKENS=4096

# Token-per-word ratio for the heuristic counter
GANESHA_TOKENS_PER_WORD=1.3

# Default pruning strategy: truncate | summarize | priority
GANESHA_PRUNE_STRATEGY=truncate

# Memory store default TTL in seconds (empty = no expiry)
GANESHA_MEMORY_TTL=
